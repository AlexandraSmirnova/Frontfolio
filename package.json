{
  "name": "frontfolio",
  "version": "1.0.0",
  "description": "Portfolio site for demonstrating skills",
  "main": "index.js",
  "scripts": {
    "type-check": "tsc --noEmit",
    "build": "webpack --mode production",
    "start": "webpack serve --mode development",
    "lint:ts": "eslint --ext .ts,.tsx src",
    "lint:fix": "eslint --ext .ts,.tsx src --fix",
    "lint": "npm run lint:ts & npm run type-check",
    "prepare": "git config core.hooksPath .git-hooks || echo 'Not in a git repo'"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/AlexandraSmirnova/Frontfolio"
  },
  "keywords": [
    "portfolio",
    "frontend",
    "skills",
    "contacts"
  ],
  "author": "Alexandra Smirnova",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/AlexandraSmirnova/Frontfolio/issues"
  },
  "homepage": "https://github.com/AlexandraSmirnova/Frontfolio#readme",
  "devDependencies": {
    "@eslint/compat": "^1.4.1",
    "@eslint/eslintrc": "^3.3.1",
    "@eslint/js": "^10.0.0",
    "@stylistic/eslint-plugin": "^5.5.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@typescript-eslint/eslint-plugin": "^8.46.4",
    "@typescript-eslint/parser": "^8.46.4",
    "copy-webpack-plugin": "^13.0.1",
    "eslint": "^9.39.1",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.37.5",
    "globals": "^16.5.0",
    "ts-loader": "^9.5.4",
    "typescript": "^5.9.3",
    "webpack": "^5.102.1",
    "webpack-cli": "^6.0.1",
    "webpack-dev-server": "^5.2.2"
  },
  "dependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --ext .ts,.tsx src --fix"
    ]
  }
}
